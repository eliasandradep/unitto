SECRET_KEY=troque-por-uma-chave-segura
DATABASE_URL=sqlite:///unitto.db

# Domínio base da aplicação, usado para detectar tenant por subdomínio
# (slug.unitto.com.br). Não precisa mudar se o app for servido só via
# unitto.com.br/t/{slug}/.
BASE_DOMAIN=unitto.com.br

# Resend (obrigatório para o "esqueci minha senha") — resend.com/api-keys
# MAIL_FROM precisa ser de um domínio verificado no Resend, ou use
# onboarding@resend.dev para testes antes de verificar unitto.com.br.
RESEND_API_KEY=
MAIL_FROM=

# Stripe (opcional — Etapa 8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://unitto.com.br/billing/checkout/sucesso
STRIPE_CANCEL_URL=https://unitto.com.br/billing/planos

# Provedor de pagamento ativo: "stripe" (padrão) ou "infinitepay"
PAYMENT_PROVIDER=stripe

# InfinitePay (Checkout Integrado) — handle da conta, sem o "$"
# ex.: se seu link é infinitepay.com/unitto, o handle é "unitto"
INFINITEPAY_HANDLE=
