SECRET_KEY=troque-por-uma-chave-segura
DATABASE_URL=sqlite:///unitto.db

# Domínio base da aplicação, usado para detectar tenant por subdomínio
# (slug.unitto.com.br). Não precisa mudar se o app for servido só via
# unitto.com.br/t/{slug}/.
BASE_DOMAIN=unitto.com.br

# SMTP (obrigatório para o "esqueci minha senha") — usando Gmail:
# SMTP_USER = seu endereço @gmail.com
# SMTP_PASSWORD = senha de app gerada em https://myaccount.google.com/apppasswords
# (a verificação em 2 etapas precisa estar ativa na conta Google para gerar a senha de app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=

# Stripe (opcional — Etapa 8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://unitto.com.br/billing/checkout/sucesso
STRIPE_CANCEL_URL=https://unitto.com.br/billing/planos
